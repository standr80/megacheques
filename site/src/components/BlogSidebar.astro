---
import type { TagCount } from '../lib/nblb';
interface Props {
  tags: TagCount[];
  activeSlug?: string;
}
const { tags, activeSlug } = Astro.props;
---
{tags.length > 0 && (
  <aside class="nblb-side">
    <h2>Browse by topic</h2>
    <ul>
      {tags.map((t) => (
        <li>
          <a href={`/blog/tags/${t.slug}/`} class={activeSlug === t.slug ? 'on' : ''}>
            <span>{t.tag}</span>
            <span class="ct">{t.count}</span>
          </a>
        </li>
      ))}
    </ul>
  </aside>
)}

<style>
  .nblb-side { border: 1px solid rgba(0,0,0,.08); border-radius: 14px; padding: 1.25rem; background: #fff; position: sticky; top: 1rem; }
  .nblb-side h2 { font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; opacity: .5; margin: 0 0 .9rem; }
  .nblb-side ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: .15rem; }
  .nblb-side a { display: flex; justify-content: space-between; align-items: center; gap: .5rem; padding: .4rem .55rem; border-radius: 8px; font-size: .9rem; text-decoration: none; color: inherit; }
  .nblb-side a:hover { background: rgba(0,0,0,.05); }
  .nblb-side a.on { background: color-mix(in srgb, var(--acc, #2563eb) 12%, transparent); font-weight: 600; }
  .nblb-side .ct { font-size: .7rem; font-weight: 600; color: var(--acc, #2563eb); }
  @media (max-width: 768px) { .nblb-side { position: static; } }
</style>
