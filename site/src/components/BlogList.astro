---
import BlogSidebar from './BlogSidebar.astro';
import type { PostSummary, TagCount } from '../lib/nblb';

interface Props {
  posts: PostSummary[];
  tags: TagCount[];
  page?: number;
  totalPages?: number;
  activeSlug?: string;
  accent?: string;
}
const { posts, tags, page = 1, totalPages = 1, activeSlug, accent = '#2563eb' } = Astro.props;

const fmt = (d: string) =>
  d ? new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) : '';
const pageHref = (n: number) => (n <= 1 ? '/blog/' : `/blog/page/${n}/`);

const items: (number | null)[] = [];
let last = 0;
for (let i = 1; i <= totalPages; i++) {
  if (i === 1 || i === totalPages || (i >= page - 1 && i <= page + 1)) {
    if (last && i - last > 1) items.push(null);
    items.push(i);
    last = i;
  }
}
---
<div class="nblb-layout" style={`--acc:${accent}`}>
  <div class="nblb-main">
    {posts.length === 0 ? (
      <p class="nblb-empty">No posts yet — check back soon!</p>
    ) : (
      <div class="nblb-grid">
        {posts.map((p) => (
          <a class="nblb-card" href={`/blog/${p.slug}/`}>
            {p.hero_image && (
              <img src={p.hero_image} alt={p.hero_image_alt || p.title} loading="lazy" width="600" height="338" />
            )}
            <div class="b">
              <h3>{p.title}</h3>
              {p.excerpt && <p>{p.excerpt}</p>}
              <span class="d">{fmt(p.published_at)}</span>
            </div>
          </a>
        ))}
      </div>
    )}

    {totalPages > 1 && (
      <nav class="nblb-pager" aria-label="Blog pages">
        {page > 1 && <a href={pageHref(page - 1)} rel="prev">← Prev</a>}
        {items.map((n) =>
          n === null ? (
            <span class="gap">…</span>
          ) : n === page ? (
            <span class="cur">{n}</span>
          ) : (
            <a href={pageHref(n)}>{n}</a>
          )
        )}
        {page < totalPages && <a href={pageHref(page + 1)} rel="next">Next →</a>}
      </nav>
    )}
  </div>

  <BlogSidebar tags={tags} activeSlug={activeSlug} />
</div>

<style>
  .nblb-layout { display: grid; grid-template-columns: 1fr 260px; gap: 2.5rem; align-items: start; max-width: 1100px; margin: 0 auto; padding: 2.5rem 1.25rem; }
  .nblb-main { min-width: 0; }
  .nblb-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  .nblb-card { display: block; border: 1px solid rgba(0,0,0,.08); border-radius: 14px; overflow: hidden; background: #fff; box-shadow: 0 1px 4px rgba(0,0,0,.06); text-decoration: none; color: inherit; transition: transform .15s, box-shadow .15s; }
  .nblb-card:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(0,0,0,.1); }
  .nblb-card img { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; background: #f4f4f5; }
  .nblb-card .b { padding: 1rem 1.1rem 1.2rem; }
  .nblb-card h3 { font-size: 1.05rem; font-weight: 700; margin: 0 0 .4rem; line-height: 1.3; }
  .nblb-card p { font-size: .875rem; opacity: .65; margin: 0 0 .7rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .nblb-card .d { font-size: .75rem; opacity: .5; }
  .nblb-empty { opacity: .6; }
  .nblb-pager { display: flex; gap: .4rem; flex-wrap: wrap; align-items: center; margin-top: 2.5rem; }
  .nblb-pager a, .nblb-pager .cur { padding: .45rem .8rem; border-radius: 8px; border: 1px solid var(--acc, #2563eb); font-size: .85rem; text-decoration: none; color: var(--acc, #2563eb); }
  .nblb-pager .cur { background: var(--acc, #2563eb); color: #fff; font-weight: 700; }
  .nblb-pager .gap { border: none; opacity: .5; }
  @media (max-width: 768px) { .nblb-layout { grid-template-columns: 1fr; gap: 1.5rem; } .nblb-grid { grid-template-columns: 1fr; } }
</style>
