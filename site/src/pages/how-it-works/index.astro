---
import Layout from '../../layouts/Layout.astro';

const steps = [
  {
    number: '1',
    icon: '🛒',
    title: 'Choose your cheque',
    body: 'Pick Single Use or Reusable, and select your size — Mini, Maxi or Mega — then check out securely online with Stripe.',
  },
  {
    number: '2',
    icon: '✏️',
    title: 'Tell us the details',
    body: 'We’ll email you almost instantly to collect the key details for your cheque: payee name, amount, message, logo and website address.',
  },
  {
    number: '3',
    icon: '👍',
    title: 'Approve your proof',
    body: 'Our in-house design team creates an artwork proof of your cheque and sends it to you for feedback and sign-off — nothing goes to print without your okay.',
  },
  {
    number: '4',
    icon: '🚚',
    title: 'We print & dispatch',
    body: 'Once approved, your cheque is manufactured within 3-5 days and sent by courier on a signed-for, next-working-day service.',
  },
];

const deliveryFacts = [
  { stat: '3–5 days', label: 'to manufacture after approval' },
  { stat: '4–5 days', label: 'total, door to door' },
  { stat: 'Next working day', label: 'signed-for courier delivery' },
  { stat: 'Parcelforce · APC · TNT', label: 'courier chosen by cheque size' },
];
---

<Layout
  title="How It Works — Ordering & Delivery"
  description="From choosing your cheque to receiving it on your doorstep: how Mega Cheques ordering, design proofing and UK delivery works."
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-blue-50 to-white">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20 text-center">
      <p class="text-sm font-semibold uppercase tracking-wide text-blue-700">How it works</p>
      <h1 class="mt-2 text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900">
        From "yes please" to your doorstep in four simple steps
      </h1>
      <p class="mt-4 text-lg text-slate-600 max-w-2xl mx-auto">
        We've kept ordering simple and quick — and you'll see and approve your design before we ever go to print.
      </p>
    </div>
  </section>

  <!-- Steps -->
  <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-16">
    <ol class="grid sm:grid-cols-2 gap-6">
      {steps.map((step) => (
        <li class="relative rounded-2xl border border-slate-200 p-8 hover:border-blue-700 hover:shadow-md transition-all">
          <div class="flex items-center gap-4">
            <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-blue-700 text-lg font-bold text-white">
              {step.number}
            </span>
            <span class="text-3xl" aria-hidden="true">{step.icon}</span>
          </div>
          <h2 class="mt-5 text-xl font-bold text-slate-900">{step.title}</h2>
          <p class="mt-2 text-slate-600">{step.body}</p>
        </li>
      ))}
    </ol>
  </section>

  <!-- Delivery -->
  <section class="bg-slate-50 py-16">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <h2 class="text-3xl font-bold tracking-tight">Delivery, sorted</h2>
        <p class="mt-3 text-slate-600">
          Once your design is approved, we get to work straight away. Here's what to expect.
        </p>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {deliveryFacts.map((fact) => (
          <div class="rounded-xl bg-white border border-slate-200 p-6 text-center">
            <p class="text-xl font-extrabold text-blue-700">{fact.stat}</p>
            <p class="mt-2 text-sm text-slate-600">{fact.label}</p>
          </div>
        ))}
      </div>
      <ul class="mt-10 space-y-3 text-slate-600">
        <li class="flex gap-3">
          <span class="text-blue-700" aria-hidden="true">✓</span>
          <span>Standard delivery runs Monday to Friday — please allow 4-5 days in total to receive your cheque.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-blue-700" aria-hidden="true">✓</span>
          <span>Add any delivery restrictions or special instructions to the order notes at checkout.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-blue-700" aria-hidden="true">✓</span>
          <span>We'll keep you posted by email every step of the way, from proof approval to dispatch.</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-blue-700">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16 text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white">Ready to get started?</h2>
      <p class="mt-3 text-blue-100">
        Order online in minutes, or call us on <a class="underline" href="tel:01842337100">01842 337 100</a> and
        we'll talk you through choosing the right cheque for your event.
      </p>
      <a href="/products/" class="mt-8 inline-flex items-center rounded-full bg-white px-6 py-3 text-base font-semibold text-blue-700 hover:bg-blue-50 transition-colors">
        Order Your Mega Cheque Now
      </a>
    </div>
  </section>
</Layout>
