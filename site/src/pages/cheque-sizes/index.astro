---
import Layout from '../../layouts/Layout.astro';
import { sizes, products } from '../../data/products';
---

<Layout
  title="Cheque Sizes, Specs & Pricing"
  description="Compare our giant cheque sizes — Mini, Maxi and Mega — across Single Use and Reusable styles, including dimensions, materials and pricing."
>
  <section class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl font-extrabold tracking-tight">Cheque Sizes &amp; Specs</h1>
    <p class="mt-4 text-slate-600">
      Our cheques are available as single use or reusable, and in three sizes — Mini, Maxi and Mega.
      All cheques are fully customisable with logos, payee names, custom messages and website addresses,
      all inclusive of the price — there are no hidden extras.
    </p>

    <div class="mt-10 overflow-x-auto">
      <table class="w-full border-collapse text-left">
        <thead>
          <tr class="border-b border-slate-200 text-sm uppercase tracking-wide text-slate-500">
            <th class="py-3 pr-4">Size</th>
            <th class="py-3 pr-4">Dimensions</th>
            <th class="py-3 pr-4">Single Use</th>
            <th class="py-3">Reusable</th>
          </tr>
        </thead>
        <tbody>
          {sizes.map((size) => (
            <tr class="border-b border-slate-100">
              <td class="py-4 pr-4 font-semibold">{size.name}</td>
              <td class="py-4 pr-4 text-slate-600">{size.dimensions}</td>
              <td class="py-4 pr-4">£{size.singleUsePrice.toFixed(2)} <span class="text-slate-400">+VAT</span></td>
              <td class="py-4">£{size.reusablePrice.toFixed(2)} <span class="text-slate-400">+VAT</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="mt-4 text-sm text-slate-500">All of our cheques are printed with high quality materials and are both sturdy and durable.</p>

    <h2 class="mt-14 text-2xl font-bold">Materials &amp; finish</h2>
    <div class="mt-6 grid sm:grid-cols-2 gap-6">
      {products.map((product) => (
        <div class="rounded-xl border border-slate-200 p-6">
          <h3 class="font-semibold">{product.name}</h3>
          <p class="mt-2 text-sm text-slate-600">{product.material}</p>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <a href="/products/" class="inline-flex items-center rounded-full bg-blue-700 px-6 py-3 text-base font-semibold text-white hover:bg-blue-800 transition-colors">
        Order Your Mega Cheque Now
      </a>
    </div>
  </section>
</Layout>
