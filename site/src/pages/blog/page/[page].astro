---
import Layout from '../../../layouts/Layout.astro';
import BlogList from '../../../components/BlogList.astro';
import { getAllPosts, topTags, PAGE_SIZE, pageCount } from '../../../lib/nblb';

const ACCENT = '#1d4ed8';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  const totalPages = pageCount(posts.length);
  const paths = [];
  for (let n = 2; n <= totalPages; n++) {
    paths.push({ params: { page: String(n) }, props: { n, totalPages } });
  }
  return paths;
}

const { n, totalPages } = Astro.props as { n: number; totalPages: number };
const posts = await getAllPosts();
const tags = topTags(posts);
const pagePosts = posts.slice((n - 1) * PAGE_SIZE, n * PAGE_SIZE);
---

<Layout
  title={`Blog — page ${n}`}
  description="Guides, ideas and news on big cheques and novelty cheque printing from the Mega Cheques team."
>
  <div style="background:#1d4ed8" class="text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10 sm:py-14">
      <h1 class="text-4xl sm:text-5xl font-extrabold">The Mega Cheques Blog</h1>
      <p class="text-white/85 text-lg mt-2">Page {n}</p>
    </div>
  </div>

  <BlogList posts={pagePosts} tags={tags} page={n} totalPages={totalPages} accent={ACCENT} />
</Layout>
