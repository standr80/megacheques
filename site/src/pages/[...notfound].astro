---
// Server-rendered catch-all. Its presence routes unmatched URLs through the
// normal render pipeline, so src/middleware.ts can 301 trailing-slash variants
// of legacy WordPress URLs before this page renders. Anything else gets a
// proper 404 page.
import Layout from '../layouts/Layout.astro';

export const prerender = false;

Astro.response.status = 404;
---

<Layout title="Page Not Found" description="Sorry, we couldn't find that page. Browse our giant novelty cheques or get in touch.">
  <section class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-24 text-center">
    <p class="text-sm font-semibold uppercase tracking-wide text-blue-700">404</p>
    <h1 class="mt-2 text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900">
      Page not found
    </h1>
    <p class="mt-4 text-lg text-slate-600">
      Sorry, we couldn't find that page. It may have moved when we updated the site.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <a href="/" class="inline-flex items-center rounded-full bg-blue-700 px-6 py-3 text-base font-semibold text-white hover:bg-blue-800 transition-colors">
        Back to home
      </a>
      <a href="/products/" class="inline-flex items-center rounded-full border border-slate-300 px-6 py-3 text-base font-semibold text-slate-700 hover:border-blue-700 hover:text-blue-700 transition-colors">
        Shop giant cheques
      </a>
    </div>
  </section>
</Layout>
