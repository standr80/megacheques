---
import Layout from '../layouts/Layout.astro';
import { sizes } from '../data/products';

const reasons = [
  {
    title: 'Big Impact',
    body: 'Oversized cheques are a great promotional tool for any company, school or organisation.',
  },
  {
    title: 'Make Size Matter',
    body: 'Reward your charity with the exposure and awareness their cause deserves.',
  },
  {
    title: 'Create Headlines',
    body: 'Jumbo charity cheques are the perfect accessory for celebrating your fundraising efforts.',
  },
  {
    title: 'Add Brand Personality',
    body: 'Customised designs that reflect your brand will grab attention and get remembered.',
  },
  {
    title: 'Free Shipping',
    body: 'Our prices include free standard UK shipping — no hidden extras.',
  },
];

const testimonials = [
  {
    quote:
      'The cheque is sturdy and had more impact than I expected — this definitely is a mega cheque! Thanks guys for such prompt service.',
    name: 'David Munday',
    location: 'Suffolk',
  },
  {
    quote: 'Thanks for producing our cheque in such a short lead time. We can’t wait to use it and we’ll be sure to recommend you.',
    name: 'Josie Hill',
    location: 'London',
  },
  {
    quote: 'Great quality and thanks for assisting us with a cheque for our school.',
    name: 'Matilda Green',
    location: 'Sheffield',
  },
];
---

<Layout
  title="Giant Novelty Cheques for Charity & Fundraising Presentations"
  description="Custom-printed giant cheques in three sizes — single use or reusable dry-wipe — perfect for charity presentations, prize-giving and fundraising events. Free UK shipping, fast turnaround."
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-blue-50 to-white">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 sm:py-24 grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900">
          Fundraising just got <span class="text-blue-700">MEGA</span>
        </h1>
        <p class="mt-6 text-lg text-slate-600">
          You won't get bigger than our giant novelty cheques. Custom printed for charity presentations,
          prize-giving awards, company charity days and fundraising events of every kind.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/products/" class="inline-flex items-center rounded-full bg-blue-700 px-6 py-3 text-base font-semibold text-white hover:bg-blue-800 transition-colors">
            Order Your Mega Cheque Now
          </a>
          <a href="/cheque-sizes/" class="inline-flex items-center rounded-full border border-slate-300 px-6 py-3 text-base font-semibold text-slate-700 hover:border-blue-700 hover:text-blue-700 transition-colors">
            See sizes &amp; pricing
          </a>
        </div>
        <p class="mt-4 text-sm text-slate-500">🔒 Secure, encrypted payments via Stripe &middot; Free UK shipping</p>
      </div>
      <div class="rounded-2xl bg-white border border-slate-200 shadow-sm p-6">
        <p class="text-sm font-semibold text-slate-500 uppercase tracking-wide">Used for</p>
        <ul class="mt-3 space-y-2 text-slate-700">
          <li>🏆 Charity presentations &amp; cheque handovers</li>
          <li>🎉 Prize-giving awards</li>
          <li>🏢 Company charity days</li>
          <li>📣 Fundraising events &amp; PR moments</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Sizes overview -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center max-w-2xl mx-auto">
      <h2 class="text-3xl font-bold tracking-tight">Mini, Maxi or Mega — your choice</h2>
      <p class="mt-3 text-slate-600">
        Available as a single-use printed cheque or a dry-wipe reusable cheque, in three sizes.
        Every cheque is fully customised with your logo, payee name, message and website address —
        all included in the price, with no hidden extras.
      </p>
    </div>
    <div class="mt-10 overflow-x-auto">
      <table class="w-full border-collapse text-left">
        <thead>
          <tr class="border-b border-slate-200 text-sm uppercase tracking-wide text-slate-500">
            <th class="py-3 pr-4">Size</th>
            <th class="py-3 pr-4">Dimensions</th>
            <th class="py-3 pr-4">Single Use</th>
            <th class="py-3">Reusable</th>
          </tr>
        </thead>
        <tbody>
          {sizes.map((size) => (
            <tr class="border-b border-slate-100">
              <td class="py-4 pr-4 font-semibold">{size.name}</td>
              <td class="py-4 pr-4 text-slate-600">{size.dimensions}</td>
              <td class="py-4 pr-4">£{size.singleUsePrice.toFixed(2)} <span class="text-slate-400">+VAT</span></td>
              <td class="py-4">£{size.reusablePrice.toFixed(2)} <span class="text-slate-400">+VAT</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <div class="mt-8 text-center">
      <a href="/products/" class="inline-flex items-center rounded-full bg-blue-700 px-6 py-3 text-base font-semibold text-white hover:bg-blue-800 transition-colors">
        Browse cheques &amp; order
      </a>
    </div>
  </section>

  <!-- Reasons -->
  <section class="bg-slate-50 py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold tracking-tight text-center">5 Reasons to Buy a Giant Cheque</h2>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-5 gap-6">
        {reasons.map((reason) => (
          <div class="rounded-xl bg-white border border-slate-200 p-5">
            <p class="font-semibold text-slate-900">{reason.title}</p>
            <p class="mt-2 text-sm text-slate-600">{reason.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-3xl font-bold tracking-tight text-center">What our customers say</h2>
    <div class="mt-10 grid sm:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <figure class="rounded-xl border border-slate-200 p-6">
          <blockquote class="text-slate-700 italic">&ldquo;{t.quote}&rdquo;</blockquote>
          <figcaption class="mt-4 text-sm font-semibold text-slate-900">
            {t.name} <span class="font-normal text-slate-500">— {t.location}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-blue-700">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16 text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white">Ready to make your presentation MEGA?</h2>
      <p class="mt-3 text-blue-100">Order online in minutes, or call us on <a class="underline" href="tel:01842337100">01842 337 100</a>.</p>
      <a href="/products/" class="mt-8 inline-flex items-center rounded-full bg-white px-6 py-3 text-base font-semibold text-blue-700 hover:bg-blue-50 transition-colors">
        Order Your Mega Cheque Now
      </a>
    </div>
  </section>
</Layout>
