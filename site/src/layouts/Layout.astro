---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonical = new URL(Astro.url.pathname, 'https://www.megacheques.co.uk');

// GA4: set PUBLIC_GA_ID (e.g. G-XXXXXXXXXX) in Vercel env vars to enable.
// Loads in Consent Mode — analytics cookies denied until the visitor accepts
// the cookie banner (UK PECR compliance).
const GA_ID = import.meta.env.PUBLIC_GA_ID;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <title>{title} | Mega Cheques</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | Mega Cheques`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://www.megacheques.co.uk/images/mega-big-cheque.webp" />
    <meta name="generator" content={Astro.generator} />
    {GA_ID && (
      <script is:inline define:vars={{ GA_ID }}>
        window.__gaId = GA_ID;
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        window.gtag = gtag;
        gtag('consent', 'default', {
          analytics_storage: 'denied',
          ad_storage: 'denied',
          ad_user_data: 'denied',
          ad_personalization: 'denied',
        });
        gtag('js', new Date());
        gtag('config', GA_ID);
        if (localStorage.getItem('cookie-consent') === 'granted') {
          gtag('consent', 'update', { analytics_storage: 'granted' });
        }
      </script>
    )}
    {GA_ID && <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>}
  </head>
  <body class="min-h-screen flex flex-col bg-white text-slate-900 antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <CookieBanner />
  </body>
</html>
